#.env ws-gateway
PORT=8007

# Postgres (Neon) - misma base que ingesta-iot
DATABASE_URL=postgresql://neondb_owner:npg_y8w4RBLTnCjS@ep-withered-fog-ajqawsrq-pooler.c-3.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Debe ser EXACTAMENTE el mismo valor que usa api-mobile para firmar sus JWT
# (config.JWTSecret allá, revisa qué variable de entorno lee config.Load()
# -- probablemente también JWT_SECRET -- y copia el mismo valor tal cual).
JWT_SECRET=kajve-secret-key-2026-production

# Redis (mismo canal user:<id> que publica ingesta-iot)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# Cuántas lecturas históricas mandar al conectar, para que la gráfica no
# arranque vacía.
HISTORY_LIMIT=100

# Origen permitido para el WebSocket. "*" permite cualquiera (útil en
# desarrollo); en producción pon el dominio real de tu app.
WS_ALLOWED_ORIGIN=*
